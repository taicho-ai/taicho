    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}