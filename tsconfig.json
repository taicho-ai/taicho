{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@taicho-ai/contracts": ["./packages/contracts/src/index.ts"],
      "@taicho-ai/contracts/*": ["./packages/contracts/src/*"],
      "@taicho-ai/telemetry": ["./packages/telemetry/src/index.ts"],
      "@taicho-ai/graph": ["./packages/graph/src/index.ts"],
      "@taicho-ai/graph/*": ["./packages/graph/src/*"],
      "@taicho-ai/agent": ["./packages/agent/src/index.ts"],
      "@taicho-ai/agent/request-timeout": ["./packages/agent/src/providers/request-timeout.ts"],
      "@taicho-ai/agent/*": ["./packages/agent/src/*"],
      "@taicho-ai/framework": ["./packages/framework/src/index.ts"],
      "@taicho-ai/framework/*": ["./packages/framework/src/*"],
      "@taicho-ai/cli": ["./packages/cli/src/index.tsx"],
      "@taicho-ai/cli/*": ["./packages/cli/src/*"]
    },
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types", "react"],
    "noEmit": true
  },
  "include": ["src", "packages", "spikes"]
}
