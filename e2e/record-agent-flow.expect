#!/usr/bin/expect -f
set timeout 20
set repo [lindex $argv 0]
set ws [lindex $argv 1]
set logfile [lindex $argv 2]

set env(TAICHO_E2E_MODEL) "agent-flow"
set env(TERM) "xterm-256color"
cd $ws

log_file -noappend $logfile
log_user 1
spawn "$repo/dist/taicho"

expect "taicho"
after 500
send -- "create a proof worker agent"
after 200
send -- "\r"

expect "New agent"
after 300
send -- "y"

expect "Created proof-agent."
after 500
send -- "use the proof worker to prove delegation works"
after 200
send -- "\r"

expect "Root used proof-agent"
after 800
send -- "\033"
expect eof
